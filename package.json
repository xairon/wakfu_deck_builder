{
  "name": "wakfu-deck-builder",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env ts-node -r tsconfig-paths/register --project tsconfig.server.json src/server/index.ts",
    "optimize-images": "tsx scripts/optimizeImages.ts",
    "clean-cards": "node scripts/generateCleanCards.js",
    "extract-illustrations": "tsx scripts/extractIllustrations.ts",
    "validate-data": "tsx scripts/validateData.ts",
    "dofus-mag-report": "tsx scripts/dofusMagMatchingReport.ts",
    "gen-dofus-mag": "tsx scripts/genDofusMagDecks.ts && prettier --write src/data/dofusMagDecks.ts",
    "compile-effects": "tsx scripts/compileEffects.ts && prettier --write \"public/data/*.json\"",
    "build": "vite build",
    "type-check": "vue-tsc --noEmit",
    "serve": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "test:unit": "vitest --environment jsdom",
    "coverage": "vitest run --coverage",
    "update-cards": "node scripts/updateCards.js",
    "download-pages": "tsx scripts/downloadPages.ts",
    "analyze-cards": "tsx scripts/analyzeCardStructure.ts",
    "parse-cards": "tsx scripts/parseCardsV2.ts",
    "analyze-types": "tsx scripts/analyzeTypes.ts",
    "migrate-images": "tsx scripts/migrateImages.ts",
    "download-images": "tsx scripts/downloadMissingImages.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@supabase/supabase-js": "^2.45.0",
    "@vueuse/core": "^10.7.0",
    "daisyui": "^4.4.19",
    "pinia": "^3.0.1",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tauri-apps/cli": "^2.7.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node18": "^18.2.4",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.0",
    "@types/glob": "^8.1.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.11",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.0",
    "async-mutex": "^0.5.0",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-vue": "^9.17.0",
    "express": "^4.21.2",
    "globals": "^16.1.0",
    "jsdom": "^26.0.0",
    "multer": "^1.4.5-lts.1",
    "p-limit": "^5.0.0",
    "pg": "^8.13.3",
    "postcss": "^8.4.32",
    "prettier": "^3.0.3",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "~5.3.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.2.10"
  }
}
