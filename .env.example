# =============================================================================
# Wakfu Deck Builder — variables d'environnement
# Copiez ce fichier en `.env` et renseignez les valeurs.
# =============================================================================

# --- Configuration application ---
VITE_APP_TITLE=Wakfu Deck Builder
VITE_API_URL=http://localhost:3000
VITE_STORAGE_PREFIX=wakfu_
VITE_DEBUG=false
VITE_CARDS_IMAGES_PATH=/images/cards
VITE_ENABLE_COLLECTION=true
VITE_ENABLE_DECK_BUILDER=true

# --- Backend Supabase (REQUIS) ---
# Application web cloud : l'authentification et les données (collection, decks)
# passent par Supabase. Sans ces variables, l'app affiche un écran « Configuration
# requise ». Voir DEPLOYMENT.md pour le pas-à-pas (création du projet + exécution
# de supabase/migrations/0001_init.sql).
#
# La clé ci-dessous est la clé "anon public" : PUBLIQUE par conception (présente
# dans le bundle frontend). N'utilisez JAMAIS la clé service_role ici.
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
